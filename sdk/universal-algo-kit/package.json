{
  "name": "universal-algo-intent-kit",
  "version": "0.1.0",
  "description": "Cross-chain intent SDK: EVM (Somnia/Ethereum) → Algorand settlement",
  "license": "MIT",
  "author": "",
  "keywords": [
    "algorand",
    "cross-chain",
    "intents",
    "ethers",
    "algosdk",
    "somnia"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "uak": "dist/cli.cjs"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"(no lint configured)\""
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "algosdk": "^2.9.0",
    "commander": "^14.0.0",
    "dotenv": "^17.3.1",
    "ethers": "^6.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.5.0",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18"
  }
}
